<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>FB2 Collection</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Syne:wght@400;700;800&display=swap" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
  <link href="/css/import.css" rel="stylesheet">
</head>
<body>

<div class="page-header">
  <div class="import-header">
    <h1>FB2 <span>Import</span></h1>
    <div class="import-btn-wrap">
      <span id="statusBadge" class="idle">idle</span>
      <button id="importBtn" onclick="startImport()">
        <span class="spinner" id="spinner"></span>
        <span id="btnLabel">▶ Run Import</span>
      </button>
    </div>
  </div>

  <div class="nav-panel d-flex gap-2 p-2">
    <a href="/" class="btn btn-outline-light btn-sm">Home</a>
    <a href="/import" class="btn btn-outline-light btn-sm">Import</a>
    <a href="/books" class="btn btn-outline-light btn-sm">Books</a>
    <a href="/authors" class="btn btn-outline-light btn-sm">Authors</a>
    <a href="/genres" class="btn btn-outline-light btn-sm">Genres</a>
    <a href="/series" class="btn btn-outline-light btn-sm">Series</a>
    <a href="/debug" class="btn btn-outline-light btn-sm">Debug</a>
    <form action="/search" method="GET" class="topbar-search">
      <input type="text" name="q" placeholder="Search..." />
    </form>
  </div>
</div>

<!-- Main stats row - includes all skip badges -->
<div class="stats-row">
  <div class="stat-card total">
    <div class="stat-label">Files Found</div>
    <div class="stat-value" id="cntTotal">0</div>
  </div>
  <div class="stat-card processed">
    <div class="stat-label">Processed</div>
    <div class="stat-value" id="cntProcessed">0</div>
  </div>
  <div class="stat-card imported">
    <div class="stat-label">Imported</div>
    <div class="stat-value" id="cntImported">0</div>
  </div>
  <div class="stat-card skipped">
    <div class="stat-label">Duplicate</div>
    <div class="stat-value" id="skipDuplicate">0</div>
  </div>
  <div class="stat-card skipped">
    <div class="stat-label">Language</div>
    <div class="stat-value" id="skipLanguage">0</div>
  </div>
  <div class="stat-card skipped">
    <div class="stat-label">Genre</div>
    <div class="stat-value" id="skipGenre">0</div>
  </div>
  <div class="stat-card skipped">
    <div class="stat-label">Author</div>
    <div class="stat-value" id="skipAuthor">0</div>
  </div>
  <div class="stat-card skipped">
    <div class="stat-label">Encoding</div>
    <div class="stat-value" id="skipEncoding">0</div>
  </div>
</div>

<!-- Progress bar -->
<div class="progress-wrap" id="progressWrap">
  <div class="progress-label">
    <span id="progressText">Processing...</span>
    <span id="progressPct">0%</span>
  </div>
  <div class="progress-track">
    <div class="progress-fill" id="progressFill"></div>
  </div>
</div>

<!-- Terminal log -->
<div class="terminal-wrap">
  <div class="terminal-header">
    <div class="dot dot-r"></div>
    <div class="dot dot-y"></div>
    <div class="dot dot-g"></div>
    <span class="terminal-title">Import log</span>
  </div>
  <div id="logBox"><span style="color:#2a3a2a">// Click "Run Import" to begin…</span></div>
</div>

<!-- Final summary -->
<div id="summaryBox">
  <h5>Import Complete</h5>
  <div class="summary-grid">
    <div>Imported: <strong id="sumImported">0</strong></div>
    <div>Duplicate: <strong id="sumDuplicate">0</strong></div>
    <div>Language: <strong id="sumLanguage">0</strong></div>
    <div>Genre: <strong id="sumGenre">0</strong></div>
    <div>Author: <strong id="sumAuthor">0</strong></div>
    <div>Encoding: <strong id="sumEncoding">0</strong></div>
  </div>
</div>

<script src="/js/import.js"></script>

</body>
</html>
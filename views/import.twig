<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Import — FB2 Collection</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Syne:wght@400;700;800&display=swap" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>

  <!-- Nav -->
  <div class="topbar">
    <a href="/">← Home</a>
    <a href="/books">Books</a>
    <a href="/authors">Authors</a>
    <a href="/genres">Genres</a>
  </div>

  <!-- Header -->
  <div class="page-header">
    <h1>FB2 <span>Import</span></h1>
    <div class="import-btn-wrap">
      <span id="statusBadge">idle</span>
      <button id="importBtn" onclick="startImport()">
        <span class="spinner" id="spinner"></span>
        <span id="btnLabel">▶ Run Import</span>
      </button>
    </div>
  </div>

  <!-- Live stat counters -->
  <div class="stats-row">
    <div class="stat-card total">
      <div class="stat-label">Files found</div>
      <div class="stat-value" id="cntTotal">—</div>
    </div>
    <div class="stat-card imported">
      <div class="stat-label">Imported</div>
      <div class="stat-value" id="cntImported">0</div>
    </div>
    <div class="stat-card skipped">
      <div class="stat-label">Skipped</div>
      <div class="stat-value" id="cntSkipped">0</div>
    </div>
    <div class="stat-card deleted">
      <div class="stat-label">Deleted</div>
      <div class="stat-value" id="cntDeleted">0</div>
    </div>
  </div>

  <!-- Progress bar -->
  <div class="progress-wrap" id="progressWrap">
    <div class="progress-label">
      <span id="progressText">Processing...</span>
      <span id="progressPct">0%</span>
    </div>
    <div class="progress-track">
      <div class="progress-fill" id="progressFill"></div>
    </div>
  </div>

  <!-- Terminal log -->
  <div class="terminal-wrap">
    <div class="terminal-header">
      <div class="dot dot-r"></div>
      <div class="dot dot-y"></div>
      <div class="dot dot-g"></div>
      <span class="terminal-title">import.log — live stream</span>
    </div>
    <div id="logBox"><span style="color:#2a3a2a">// Click "Run Import" to begin…</span></div>
  </div>

  <!-- Final summary -->
  <div id="summaryBox">
    <h5>✓ Import Complete</h5>
    <div class="summary-grid">
      <div class="summary-item">
        <span class="n" id="sumImported" style="color:var(--accent)">0</span>
        <span class="l">imported</span>
      </div>
      <div class="summary-item">
        <span class="n" id="sumSkipped" style="color:var(--warn)">0</span>
        <span class="l">skipped</span>
      </div>
      <div class="summary-item">
        <span class="n" id="sumDeleted" style="color:var(--danger)">0</span>
        <span class="l">deleted</span>
      </div>
    </div>
  </div>

<script>
  let imported = 0, skipped = 0, deleted = 0, total = null, processed = 0;

  function setStatus(s, label) {
    const b = document.getElementById('statusBadge');
    b.className = s;
    b.textContent = label;
  }

  function classify(line) {
    if (line.startsWith('---')) return 'separator';
    if (line.startsWith('Index:')) return 'index';
    if (line.startsWith('File:')) return 'file';
    if (line.includes('IMPORTED')) return 'resolution-imported';
    if (line.includes('SKIPPED')) return 'resolution-skipped';
    if (line.startsWith('Error:')) return 'resolution-error';
    if (line.startsWith('Done:') || line.startsWith('Imported:') || line.startsWith('Skipped:') || line.startsWith('Deleted:')) return 'summary';
    return '';
  }

  function appendLog(line) {
    const box = document.getElementById('logBox');
    const span = document.createElement('span');
    span.className = 'log-line ' + classify(line);
    span.textContent = line + '\n';
    box.appendChild(span);
    box.scrollTop = box.scrollHeight;
  }

  function updateProgress() {
    if (!total) return;
    const pct = Math.min(100, Math.round((processed / total) * 100));
    document.getElementById('progressFill').style.width = pct + '%';
    document.getElementById('progressPct').textContent = pct + '%';
    document.getElementById('progressText').textContent = `Processing ${processed} / ${total}`;
  }

  function parseLine(line) {
    const mTotal = line.match(/^Found (\d+) files/);
    if (mTotal) { total = parseInt(mTotal[1]); document.getElementById('cntTotal').textContent = total; updateProgress(); return; }

    if (line.includes('Resolution: IMPORTED')) { imported++; document.getElementById('cntImported').textContent = imported; processed++; updateProgress(); }
    if (line.includes('Resolution: SKIPPED'))  { skipped++;  document.getElementById('cntSkipped').textContent  = skipped;  processed++; updateProgress(); }
    if (line.includes('Deleted: true'))        { deleted++;  document.getElementById('cntDeleted').textContent  = deleted; }
  }

  async function startImport() {
    const btn = document.getElementById('importBtn');
    btn.disabled = true;
    document.getElementById('spinner').style.display = 'block';
    document.getElementById('btnLabel').textContent = 'Running…';
    setStatus('running', 'running');

    document.getElementById('logBox').innerHTML = '';
    document.getElementById('progressWrap').classList.add('visible');
    document.getElementById('summaryBox').classList.remove('visible');
    imported = skipped = deleted = processed = 0; total = null;
    ['cntImported','cntSkipped','cntDeleted'].forEach(id => document.getElementById(id).textContent = '0');
    document.getElementById('cntTotal').textContent = '—';

    try {
      const resp = await fetch('/import-stream');
      const reader = resp.body.getReader();
      const decoder = new TextDecoder();
      let buf = '';

      while (true) {
        const { value, done } = await reader.read();
        if (done) break;
        buf += decoder.decode(value, { stream: true });
        const lines = buf.split('\n');
        buf = lines.pop();
        for (const line of lines) {
          if (!line.startsWith('data:')) continue;
          const msg = line.slice(5).trim();
          if (msg === '[DONE]') break;
          parseLine(msg);
          appendLog(msg);
        }
      }

      // Final summary
      document.getElementById('sumImported').textContent = imported;
      document.getElementById('sumSkipped').textContent  = skipped;
      document.getElementById('sumDeleted').textContent  = deleted;
      document.getElementById('summaryBox').classList.add('visible');
      document.getElementById('progressFill').style.width = '100%';
      document.getElementById('progressPct').textContent = '100%';
      setStatus('done', 'done');

    } catch (e) {
      appendLog('Error: ' + e.message);
      setStatus('error', 'error');
    }

    btn.disabled = false;
    document.getElementById('spinner').style.display = 'none';
    document.getElementById('btnLabel').textContent = '▶ Run Import';
  }
</script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    {% include "partials/header.twig" %}
    <title>FB2 Collection - Import</title>
</head>
<body class="bg-dark text-light">
<div class="container-fluid">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <h1 class="display-4 fw-bold">FB2 <span class="text-success">Import</span></h1>
        {% include "partials/menu.twig" %}
    </div>


<!-- Standard Bootstrap 5 Button Group - Consistent Style -->
<div class="mb-4">
    <div class="btn-group flex-wrap" role="group" aria-label="Import Statistics">

        <button type="button" class="btn btn-outline-warning align-items-center"  id="importBtn" onclick="startImport()" >
            <span id="btnLabel">Run Import</span>
        </button>
        
        <button type="button" class="btn btn-outline-primary" id="btnTotal">
            Found : <span id="cntTotal">0</span>
        </button>
        
        <button type="button" class="btn btn-outline-primary" id="btnProcessed">
            Processed : <span id="cntProcessed">0</span>
        </button>
        
        <button type="button" class="btn btn-outline-primary" id="btnImported">
            Imported : <span id="cntImported">0</span>
        </button>
        
        <button type="button" class="btn btn-outline-primary" id="btnSkipDuplicate">
            Duplicate : <span id="skipDuplicate">0</span>
        </button>
        
        <button type="button" class="btn btn-outline-primary" id="btnSkipLanguage">
            Language : <span id="skipLanguage">0</span>
        </button>
        
        <button type="button" class="btn btn-outline-primary" id="btnSkipGenre">
            Genre : <span id="skipGenre">0</span>
        </button>
        
        <button type="button" class="btn btn-outline-primary" id="btnSkipAuthor">
            Author : <span id="skipAuthor">0</span>
        </button>
        
        <button type="button" class="btn btn-outline-primary" id="btnSkipEncoding">
            Encoding : <span id="skipEncoding">0</span>
        </button>
        
    </div>
</div>

    <!-- Progress Bar -->
    <div class="progress-wrap mb-4" id="progressWrap" style="display:none;">
        <div class="d-flex justify-content-between small mb-1 text-muted">
            <span id="progressText">Processing...</span>
            <span id="progressPct">0%</span>
        </div>
        <div class="progress" style="height: 8px;">
            <div id="progressFill" class="progress-bar bg-gradient" style="width:0%"></div>
        </div>
    </div>

    <!-- Terminal Log -->
    <div class="card bg-black border-secondary mb-4">
        <div class="card-header d-flex align-items-center gap-2 bg-secondary border-0">
            <div class="d-flex gap-1">
                <div class="rounded-circle bg-danger" style="width:12px;height:12px;"></div>&nnsp;
                <div class="rounded-circle bg-warning" style="width:12px;height:12px;"></div>&nnsp;
                <div class="rounded-circle bg-success" style="width:12px;height:12px;"></div>
            </div>
            <span class="ms-2 fw-mono text-muted">Import log</span>
        </div>
        <div id="logBox" class="card-body p-3 font-mono" style="background:#0a0a0a; min-height:520px; overflow-y:auto; color:#7c9e7c;">
            <span style="color:#2a3a2a">// Click "Run Import" to begin…</span>
        </div>
    </div>


</div>

{% include "partials/footer.twig" %}
</body>
</html>
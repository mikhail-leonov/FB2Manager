<!DOCTYPE html>
<html lang="en">
<head>
    {% include "partials/header.twig" %}
    <title>FB2 Collection - Book Info</title>
</head>
<body class="bg-dark text-light">
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-end mb-4 flex-wrap gap-3">
        <h1 class="display-4 fw-bold">FB2 <span class="text-success">Book</span></h1>
        {% include "partials/menu.twig" %}
    </div>

    <div class="card bg-black border-secondary mb-4">
        <div class="card-header d-flex align-items-center gap-2 bg-secondary border-0">
            <div class="d-flex gap-1">
                <div class="rounded-circle bg-danger" style="width:12px;height:12px;"></div>&nbsp;
                <div class="rounded-circle bg-warning" style="width:12px;height:12px;"></div>&nbsp;
                <div class="rounded-circle bg-success" style="width:12px;height:12px;"></div>
            </div>
            <span class="ms-2 fw-mono text-muted">Read {{ title }}</span>
            {% include "partials/like.twig" %}
        </div>
        
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-dark table-striped table-bordered align-middle">
                    <tbody>
                        <tr>
                            <th style="width:180px;">Book ID</th>
                            <td>{{ book.book_id }}</td>
                        </tr>
                        <tr>
                            <th>Hash</th>
                            <td><code>{{ book.hash }}</code></td>
                        </tr>
                        <tr>
                            <th>Language</th>
                            <td>{{ book.language }}</td>
                        </tr>
                        <tr>
                            <th>Authors</th>
                            <td>{{ book.Authors | raw }}</td>
                        </tr>
                        <tr>
                            <th>Genres</th>
                            <td>{{ book.Genres | raw }}</td>
                        </tr>
                        <tr>
                            <th>Series</th>
                            <td>{{ book.Serie | raw }}</td>
                        </tr>
                        <tr>
                            <th>Publication</th>
                            <td>{{ book.publication_date }}</td>
                        </tr>
                        <tr>
                            <th>Action</th>
                            <td>
                                <a href="/files/{{ book.hash }}" class="btn btn-outline-light btn-sm">Read</a>
                                <a href="/files/{{ book.hash }}.fb2" download class="btn btn-outline-success btn-sm">Download FB2</a>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Annotation Card -->
    <div class="card bg-black border-secondary">
        <div class="card-header bg-secondary">
            <strong>Annotation</strong>
        </div>
        <div class="card-body">
            {{ book.annotation|raw }}
        </div>
    </div>
</div>

{% include "partials/footer.twig" %}
</body>
</html>
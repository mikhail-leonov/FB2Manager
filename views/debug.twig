<!DOCTYPE html>
<html lang="en">
<head>
    {% include "partials/header.twig" %}
    <title>FB2 Collection - Debug</title>
</head>
<body class="bg-dark text-light">
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-end mb-4 flex-wrap gap-3">
        <h1 class="display-4 fw-bold">FB2 <span class="text-success">Debug</span></h1>
        {% include "partials/menu.twig" %}
    </div>

    <div class="card bg-black border-secondary">

        <div class="card-header d-flex align-items-center gap-2 bg-secondary border-0">
            <div class="d-flex gap-1">
                <div class="rounded-circle bg-danger" style="width:12px;height:12px;"></div>&nbsp;
                <div class="rounded-circle bg-warning" style="width:12px;height:12px;"></div>&nbsp;
                <div class="rounded-circle bg-success" style="width:12px;height:12px;"></div>
            </div>
            <span class="ms-2 fw-mono text-muted">Debug Console — Results</span>
        </div>

        <div class="card-body p-0">
            <div class="row g-0">
                <div class="col-lg-2 col-md-3 border-end border-secondary bg-black p-3">
                    <h5 class="text-white mb-3">Information</h5>
                    <div class="d-flex flex-column gap-1">
                        <a class="btn btn-dark text-start debug-link" data-url="/db-stats?json=1">Statistics</a>
                        <a class="btn btn-dark text-start debug-link" data-url="/db-schema?json=1">Schema</a>
                        <a class="btn btn-dark text-start debug-link" data-url="/db?json=1">Full Dump</a>
                    </div>
                    
                    <h5 class="text-white mt-4 mb-3">Table Data</h5>
                    <div class="d-flex flex-column gap-1">
                        <a class="btn btn-dark text-start debug-link" data-url="/db/Books?json=1">Books</a>
                        <a class="btn btn-dark text-start debug-link" data-url="/db/Authors?json=1">Authors</a>
                        <a class="btn btn-dark text-start debug-link" data-url="/db/Genres?json=1">Genres</a>
                        <a class="btn btn-dark text-start debug-link" data-url="/db/Series?json=1">Series</a>
                        <!-- ... other tables ... -->
                    </div>
                </div>
                <div class="col-lg-10 col-md-9" id="log-area" style="background:#0a0a0a; min-height:650px; overflow-y:auto; padding:1rem; font-family:'JetBrains Mono',monospace;">
                    <span class="log-line" style="color:#2a3a2a">// Debug console ready</span><br>
                    <span class="log-line" style="color:#2a3a2a">// Click any action from the left panel</span>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="/js/debug.js"></script>

{% include "partials/footer.twig" %}
</body>
</html>

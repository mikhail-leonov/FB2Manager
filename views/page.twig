<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>{{title}}</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { font-size: 14px; }
    table { font-size: 13px; }
    td { max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    pre { background:#111; color:#0f0; padding:10px; }
  </style>
</head>
<body class="p-3">
  <div class="container-fluid">

    <h3 class="mb-3">{{title}}</h3>

    <div class="mb-3 d-flex flex-wrap">
      <a href="/" class="btn btn-outline-dark me-2 mb-2">Home</a>
      <a href="/import" class="btn btn-outline-dark me-2 mb-2">Import</a>
      <a href="/books" class="btn btn-outline-dark me-2 mb-2">Full books</a>
    </div>

    {% if page %}
    <nav class="mb-3">
      <ul class="pagination">

        {% if hasPrev %}
        <li class="page-item">
          <a class="page-link" href="{{path}}?page={{page - 1}}">Previous</a>
        </li>
        {% endif %}

        <li class="page-item active">
          <span class="page-link">Page {{page}}</span>
        </li>

        {% if hasNext %}
        <li class="page-item">
          <a class="page-link" href="{{path}}?page={{page + 1}}">Next</a>
        </li>
        {% endif %}

      </ul>
    </nav>
    {% endif %}

    <div>
      {{content|raw}}
    </div>

  </div>

  <script src="/js/app.js"></script>
</body>
</html>
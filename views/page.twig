<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>{{title}}</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Syne:wght@400;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0d0f12;
      --surface: #151820;
      --surface2: #1c2030;
      --border: #252a38;
      --accent: #4ade80;
      --accent2: #22d3ee;
      --warn: #fbbf24;
      --danger: #f87171;
      --text: #e2e8f0;
      --muted: #64748b;
      --mono: 'JetBrains Mono', monospace;
      --sans: 'Syne', sans-serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      font-size: 14px;
      min-height: 100vh;
      padding: 2rem;
    }

    /* Nav */
    .topbar {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 3rem;
      flex-wrap: wrap;
    }
    .topbar a {
      font-family: var(--mono);
      font-size: .75rem;
      color: var(--muted);
      text-decoration: none;
      border: 1px solid var(--border);
      padding: .3rem .7rem;
      border-radius: 4px;
      transition: color .2s, border-color .2s;
    }
    .topbar a:hover { color: var(--text); border-color: var(--accent); }
    .topbar a.active { color: var(--accent); border-color: var(--accent); }

    /* Header */
    .page-header {
      margin-bottom: 2rem;
    }
    .page-header h1 {
      font-size: 2.2rem;
      font-weight: 800;
      letter-spacing: -.04em;
      line-height: 1;
      color: var(--text);
    }
    .page-header h1 span { color: var(--accent); }

    /* Pagination */
    .pagination {
      display: flex;
      gap: .4rem;
      list-style: none;
      padding: 0;
      margin-bottom: 2rem;
    }
    .page-item .page-link {
      font-family: var(--mono);
      font-size: .75rem;
      padding: .35rem .8rem;
      background: var(--surface);
      color: var(--muted);
      border: 1px solid var(--border);
      border-radius: 4px;
      text-decoration: none;
      transition: color .2s, border-color .2s;
      display: block;
    }
    .page-item .page-link:hover { color: var(--text); border-color: var(--accent2); }
    .page-item.active .page-link { color: var(--accent2); border-color: var(--accent2); }

    /* Table */
    .table {
      width: 100%;
      border-collapse: collapse;
      font-family: var(--mono);
      font-size: .78rem;
    }
    .table thead tr {
      border-bottom: 1px solid var(--border);
    }
    .table th {
      padding: .6rem 1rem;
      color: var(--muted);
      font-weight: 700;
      letter-spacing: .08em;
      text-transform: uppercase;
      font-size: .65rem;
      text-align: left;
      white-space: nowrap;
    }
    .table td {
      padding: .55rem 1rem;
      color: var(--text);
      border-bottom: 1px solid var(--border);
      max-width: 320px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      vertical-align: middle;
    }
    .table tbody tr { transition: background .15s; }
    .table tbody tr:hover { background: var(--surface); }

    /* Links inside table cells */
    .table td a {
      color: var(--accent2);
      text-decoration: none;
    }
    .table td a:hover { color: var(--accent); text-decoration: underline; }

    /* JSON pre block */
    pre {
      background: #080a0d;
      border: 1px solid var(--border);
      border-radius: 10px;
      color: #4ade80;
      font-family: var(--mono);
      font-size: .78rem;
      line-height: 1.6;
      padding: 1.2rem 1.4rem;
      overflow-x: auto;
      white-space: pre-wrap;
      word-break: break-all;
    }
.table {
  width: 100%;
  border-collapse: collapse;
  font-family: var(--mono);
  font-size: .78rem;
}

.table thead tr {
  border-bottom: 1px solid var(--border);
}

.table th {
  padding: .6rem 1rem;
  color: var(--muted);
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  font-size: .65rem;
  text-align: left;
  white-space: nowrap;
}

.table td {
  padding: .55rem 1rem;
  color: var(--text);
  border-bottom: 1px solid var(--border);
  max-width: 320px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  vertical-align: middle;
}

.table tbody tr {
  transition: background .15s;
}

.table tbody tr:hover {
  background: var(--surface);
}

.table td a {
  color: var(--accent2);
  text-decoration: none;
}

.table td a:hover {
  color: var(--accent);
  text-decoration: underline;
}

.table {
  --bs-table-bg: transparent;
  --bs-table-accent-bg: transparent;
  --bs-table-striped-bg: transparent;
  --bs-table-hover-bg: var(--surface);
  --bs-table-border-color: var(--border);

  background: transparent !important;
}
    /* No data */
    p { color: var(--muted); font-family: var(--mono); font-size: .85rem; }

    @media (max-width: 600px) {
      body { padding: 1rem; }
      .page-header h1 { font-size: 1.6rem; }
    }
  </style>
</head>
<body>

  <div class="topbar">
    <a href="/" {% if path == '/' %}class="active"{% endif %}>← Home</a>
    <a href="/import" {% if path == '/import' %}class="active"{% endif %}>Import</a>
    <a href="/books" {% if path == '/books' %}class="active"{% endif %}>Books</a>
    <a href="/authors" {% if path == '/authors' %}class="active"{% endif %}>Authors</a>
    <a href="/genres" {% if path == '/genres' %}class="active"{% endif %}>Genres</a>
    <a href="/series" {% if path == '/series' %}class="active"{% endif %}>Series</a>
  </div>

  <div class="page-header">
    <h1>{{ title }}</h1>
  </div>

  {% if page %}
  <nav>
    <ul class="pagination">
      {% if hasPrev %}
      <li class="page-item">
        <a class="page-link" href="{{ path }}?page={{ page - 1 }}">← Prev</a>
      </li>
      {% endif %}

      <li class="page-item active">
        <span class="page-link">Page {{ page }}</span>
      </li>

      {% if hasNext %}
      <li class="page-item">
        <a class="page-link" href="{{ path }}?page={{ page + 1 }}">Next →</a>
      </li>
      {% endif %}
    </ul>
  </nav>
  {% endif %}

  <div>
    {{ content|raw }}
  </div>

  <script src="/js/app.js"></script>
</body>
</html>
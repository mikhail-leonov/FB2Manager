<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>{{title}}</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { font-size: 14px; }
    table { font-size: 13px; }
    td { max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    pre { background:#111; color:#0f0; padding:10px; }
  </style>
</head>
<body class="p-3">
  <div class="container-fluid">

    <h3 class="mb-3">{{title}}</h3>

    <div class="mb-3 d-flex flex-wrap">
      <a href="/" class="btn btn-outline-dark me-2 mb-2">Home</a>

      <a href="/import" class="btn btn-outline-dark me-2 mb-2">Import</a>
      <a href="/books" class="btn btn-outline-dark me-2 mb-2">Full books</a>

      <a href="/db" class="btn btn-outline-dark me-2 mb-2">DB All</a>
      <a href="/db/Books" class="btn btn-outline-dark me-2 mb-2">Books</a>
      <a href="/db/Authors" class="btn btn-outline-dark me-2 mb-2">Authors</a>
      <a href="/db/Genres" class="btn btn-outline-dark me-2 mb-2">Genres</a>
      <a href="/db/BookAuthors" class="btn btn-outline-dark me-2 mb-2">Book Authors</a>
      <a href="/db/BookGenres" class="btn btn-outline-dark me-2 mb-2">Book Genres</a>
      <a href="/db/BookSeries" class="btn btn-outline-dark me-2 mb-2">Book Series</a>

      <a href="/db-stats" class="btn btn-outline-dark me-2 mb-2">Stats</a>
      <a href="/db-schema" class="btn btn-outline-dark me-2 mb-2">Schema</a>
      <a href="/db-clean" class="btn btn-outline-danger me-2 mb-2">Clean DB</a>
    </div>

    <div>
      {{content|raw}}
    </div>

  </div>
  <script src="/js/app.js"></script>
</body>
</html>
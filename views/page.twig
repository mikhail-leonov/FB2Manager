<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>FB2 Collection</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Syne:wght@400;700;800&display=swap" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>

<div class="page-header">
  <h1>FB2 <span>Collection</span></h1>
  <div class="nav-panel d-flex gap-2 p-2">
    <a href="/" class="btn btn-outline-light btn-sm">Home</a>
    <a href="/import" class="btn btn-outline-light btn-sm">Import</a>
    <a href="/books" class="btn btn-outline-light btn-sm">Books</a>
    <a href="/authors" class="btn btn-outline-light btn-sm">Authors</a>
    <a href="/genres" class="btn btn-outline-light btn-sm">Genres</a>
    <a href="/series" class="btn btn-outline-light btn-sm">Series</a>
    <a href="/debug" class="btn btn-outline-light btn-sm">Debug</a>
    <form action="/search" method="GET" class="topbar-search">
      <input type="text" name="q" placeholder="Search..." />
    </form>
  </div>
</div>

  {% if page %}
  <nav>
    <ul class="pagination">
      {% if hasPrev %}
      <li class="page-item">
        <a class="page-link" href="{{ path }}?page={{ page - 1 }}{% if sort %}&sort={{ sort }}{% endif %}{% if order %}&order={{ order }}{% endif %}">← Prev</a>
      </li>
      {% endif %}

      <li class="page-item active">
        <span class="page-link">Page {{ page }}{% if limit %} ({{ limit }} per page){% endif %}</span>
      </li>

      {% if hasNext %}
      <li class="page-item">
        <a class="page-link" href="{{ path }}?page={{ page + 1 }}{% if sort %}&sort={{ sort }}{% endif %}{% if order %}&order={{ order }}{% endif %}">Next →</a>
      </li>
      {% endif %}
    </ul>
  </nav>
  {% endif %}

  <div>
    {{ content|raw }}
  </div>

  <script src="/js/app.js"></script>
</body>
</html>
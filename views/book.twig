<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>{{ title }}</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { max-width: 860px; margin: 40px auto; padding: 0 20px; font-size: 18px; line-height: 1.8; }
    h2 { margin-top: 2em; font-size: 1.4em; text-align: center; }
    h3 { margin-top: 1.5em; font-size: 1.1em; }
    p { margin: 0.5em 0; text-indent: 1.5em; }
    blockquote { border-left: 3px solid #ccc; padding-left: 1em; color: #555; }
    .poem { margin: 1em 2em; font-style: italic; }
    .stanza { margin-bottom: 1em; }
    .verse { line-height: 1.6; }
    section { margin-bottom: 2em; }
  </style>
</head>
<body>
  {{ content|raw }}
</body>
</html>
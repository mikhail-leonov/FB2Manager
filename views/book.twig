<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Read a book — FB2 Collection</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Syne:wght@400;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0d0f12;
      --surface: #151820;
      --surface2: #1c2030;
      --border: #252a38;
      --accent: #4ade80;
      --accent2: #22d3ee;
      --warn: #fbbf24;
      --danger: #f87171;
      --text: #e2e8f0;
      --muted: #64748b;
      --mono: 'JetBrains Mono', monospace;
      --sans: 'Syne', sans-serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      min-height: 100vh;
      padding: 2rem;
    }

    /* ── Nav ── */
    .topbar {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 3rem;
    }
    .topbar a {
      font-family: var(--mono);
      font-size: .75rem;
      color: var(--muted);
      text-decoration: none;
      border: 1px solid var(--border);
      padding: .3rem .7rem;
      border-radius: 4px;
      transition: color .2s, border-color .2s;
    }
    .topbar a:hover { color: var(--text); border-color: var(--accent); }

    /* ── Header ── */
    .page-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 2.5rem;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .page-header h1 {
      font-size: 2.8rem;
      font-weight: 800;
      letter-spacing: -.04em;
      line-height: 1;
    }
    .page-header h1 span { color: var(--accent); }

    /* ── Stats row ── */
    .stats-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 1rem;
      margin-bottom: 2rem;
    }
    .stat-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.2rem 1.4rem;
      position: relative;
      overflow: hidden;
      transition: border-color .2s;
    }
    .stat-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(74,222,128,.04) 0%, transparent 60%);
      pointer-events: none;
    }
    .stat-card.imported { border-color: #22543d; }
    .stat-card.skipped  { border-color: #7c3d00; }
    .stat-card.deleted  { border-color: #581c1c; }
    .stat-card.total    { border-color: #1e3a5f; }

    .stat-label {
      font-family: var(--mono);
      font-size: .65rem;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: .5rem;
    }
    .stat-value {
      font-family: var(--mono);
      font-size: 2.4rem;
      font-weight: 700;
      line-height: 1;
      transition: color .3s;
    }
    .stat-card.imported .stat-value { color: var(--accent); }
    .stat-card.skipped  .stat-value { color: var(--warn); }
    .stat-card.deleted  .stat-value { color: var(--danger); }
    .stat-card.total    .stat-value { color: var(--accent2); }

    /* ── Import button ── */
    .import-btn-wrap { display: flex; align-items: center; gap: 1rem; }

    #importBtn {
      font-family: var(--sans);
      font-weight: 700;
      font-size: 1rem;
      letter-spacing: .03em;
      padding: .85rem 2.2rem;
      background: var(--accent);
      color: #0a1a10;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: .6rem;
      transition: background .2s, transform .1s;
    }
    #importBtn:hover:not(:disabled) { background: #22c55e; transform: translateY(-1px); }
    #importBtn:active:not(:disabled) { transform: translateY(0); }
    #importBtn:disabled { opacity: .5; cursor: not-allowed; }

    .spinner {
      width: 16px; height: 16px;
      border: 2px solid rgba(0,0,0,.3);
      border-top-color: #0a1a10;
      border-radius: 50%;
      animation: spin .7s linear infinite;
      display: none;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    #statusBadge {
      font-family: var(--mono);
      font-size: .75rem;
      padding: .3rem .8rem;
      border-radius: 999px;
      background: var(--surface2);
      border: 1px solid var(--border);
      color: var(--muted);
    }
    #statusBadge.running { color: var(--accent2); border-color: var(--accent2); }
    #statusBadge.done    { color: var(--accent);  border-color: var(--accent); }
    #statusBadge.error   { color: var(--danger);  border-color: var(--danger); }

    /* ── Progress bar ── */
    .progress-wrap {
      margin-bottom: 2rem;
      display: none;
    }
    .progress-wrap.visible { display: block; }
    .progress-label {
      font-family: var(--mono);
      font-size: .7rem;
      color: var(--muted);
      margin-bottom: .4rem;
      display: flex;
      justify-content: space-between;
    }
    .progress-track {
      height: 4px;
      background: var(--surface2);
      border-radius: 999px;
      overflow: hidden;
    }
    .progress-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--accent), var(--accent2));
      border-radius: 999px;
      width: 0%;
      transition: width .4s ease;
    }

    /* ── Log terminal ── */
    .terminal-wrap {
      background: #080a0d;
      border: 1px solid var(--border);
      border-radius: 10px;
      overflow: hidden;
    }
    .terminal-header {
      background: var(--surface);
      padding: .6rem 1rem;
      display: flex;
      align-items: center;
      gap: .5rem;
      border-bottom: 1px solid var(--border);
    }
    .dot { width: 10px; height: 10px; border-radius: 50%; }
    .dot-r { background: #ff5f57; }
    .dot-y { background: #febc2e; }
    .dot-g { background: #28c840; }
    .terminal-title {
      font-family: var(--mono);
      font-size: .7rem;
      color: var(--muted);
      margin-left: .5rem;
    }

    #logBox {
      font-family: var(--mono);
      font-size: .78rem;
      line-height: 1.6;
      color: #7c9e7c;
      padding: 1rem 1.2rem;
      height: 420px;
      overflow-y: auto;
      white-space: pre-wrap;
      word-break: break-all;
    }
    #logBox::-webkit-scrollbar { width: 4px; }
    #logBox::-webkit-scrollbar-track { background: transparent; }
    #logBox::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

    .log-line { display: block; }
    .log-line.separator { color: #2a3a2a; }
    .log-line.resolution-imported { color: var(--accent); font-weight: 700; }
    .log-line.resolution-skipped  { color: var(--warn); }
    .log-line.resolution-error    { color: var(--danger); }
    .log-line.file    { color: var(--accent2); }
    .log-line.index   { color: #a78bfa; }
    .log-line.done    { color: var(--accent); font-weight: 700; }
    .log-line.summary { color: #e2e8f0; }

    /* ── Final summary box ── */
    #summaryBox {
      display: none;
      margin-top: 1.5rem;
      background: var(--surface);
      border: 1px solid var(--accent);
      border-radius: 10px;
      padding: 1.5rem;
    }
    #summaryBox.visible { display: block; }
    #summaryBox h5 {
      font-family: var(--mono);
      font-size: .75rem;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 1rem;
    }
    .summary-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
      gap: .8rem;
    }
    .summary-item { text-align: center; }
    .summary-item .n {
      font-family: var(--mono);
      font-size: 2rem;
      font-weight: 700;
      display: block;
    }
    .summary-item .l {
      font-family: var(--mono);
      font-size: .65rem;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: .1em;
    }

.table {
  width: 100%;
  border-collapse: collapse;
  font-family: var(--mono);
  font-size: .78rem;
}

.table thead tr {
  border-bottom: 1px solid var(--border);
}

.table th {
  padding: .6rem 1rem;
  color: var(--muted);
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  font-size: .65rem;
  text-align: left;
  white-space: nowrap;
}

.table td {
  padding: .55rem 1rem;
  color: var(--text);
  border-bottom: 1px solid var(--border);
  max-width: 320px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  vertical-align: middle;
}

.table tbody tr {
  transition: background .15s;
}

.table tbody tr:hover {
  background: var(--surface);
}

.table td a {
  color: var(--accent2);
  text-decoration: none;
}

.table td a:hover {
  color: var(--accent);
  text-decoration: underline;
}

.table {
  --bs-table-bg: transparent;
  --bs-table-accent-bg: transparent;
  --bs-table-striped-bg: transparent;
  --bs-table-hover-bg: var(--surface);
  --bs-table-border-color: var(--border);

  background: transparent !important;
}
    @media (max-width: 600px) {
      body { padding: 1rem; }
      .page-header h1 { font-size: 2rem; }
      #logBox { height: 280px; }
    }
  </style>
</head>
<body>
  {{ content|raw }}
</body>
</html>